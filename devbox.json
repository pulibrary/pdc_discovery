{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "ruby@3.3.2",
    "nodejs@18.17.0",
    "yarn@1.22.19",
    "postgresql@15.7",
    "stdenv",
    "libyaml@0.2.5",
    "pkg-config@latest",
    "gcc@latest",
    "gnumake@latest",
    "autoconf@latest",
    "jdk11@latest",
    "jq@latest",
    "git@latest",
    "chromedriver@latest",
    "libxml2@latest",
    "xmlsec@latest"
  ],
  "env": {
    "DEVBOX":             "1",
    "BUNDLER_VERSION":    "2.5.9",
    "PGDATA":             "$PWD/.postgres/data",
    "PGHOST":             "$PWD/.postgres",
    "PGPORT":             "5432",
    "PGUSER":             "$USER",
    "PGDATABASE":         "pdc_discovery_dev",
    "APP_DB_HOST":        "$PWD/.postgres",
    "APP_DB_USERNAME":    "$USER",
    "APP_DB":             "pdc_discovery_dev",
    "BUNDLE_BUILD_PSYCH": "--with-libyaml-dir=$(devbox path libyaml) --with-pkg-config=$(devbox path pkg-config)/bin/pkg-config"
  },
  "shell": {
    "init_hook": [
      "echo 'Environment Ready'",
      "mkdir -p \"$PGHOST\" \"$PGDATA\"",
      "test -d \"$PGDATA/base\" || initdb -D \"$PGDATA\" -A trust"
    ],
    "scripts": {
      "setup":          ["devbox run deps"],
      "deps":           "gem install -N bundler -v $BUNDLER_VERSION && bundle install && yarn install",
      "server":         "bundle exec rails s",
      "postgres-start": "pg_ctl -D \"$PGDATA\" -l \"$PGHOST/postgres.log\" -o \"-k $PGHOST\" start",
      "postgres-stop":  "pg_ctl -D \"$PGDATA\" stop"
    }
  }
}
