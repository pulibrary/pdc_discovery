{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "ruby@3.3.2",
    "nodejs@24",
    "yarn@4.13.0",
    "postgresql@15.7",
    "stdenv",
    "libyaml@0.2.5",
    "pkg-config@latest",
    "gcc@latest",
    "gnumake@latest",
    "autoconf@latest",
    "jdk11@latest",
    "jq@latest",
    "git@latest",
    "chromedriver@latest",
    "libxml2@latest",
    "xmlsec@latest",
    "libyaml.dev",
    "selenium-manager@latest"
  ],
  "env": {
    "DEVBOX":          "1",
    "BUNDLER_VERSION": "2.5.9"
  },
  "shell": {
    "init_hook": [
      "echo 'Environment Ready'"
    ],
    "scripts": {
      "setup":  ["devbox run deps"],
      "deps":   "gem install -N bundler -v $BUNDLER_VERSION && bundle install && yarn install",
      "server": "bundle exec rails s"
    }
  }
}
